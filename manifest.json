{
  "name": "Ufora Shortcuts",
  "version": "2.4",
  "description": "Adds keyboard shortcuts to Ufora video players and UI! Saves a lot of time and makes it easier to navigate through videos.",
  "manifest_version": 3,
  "icons": {
    "16": "media/icon-16.png",
    "32": "media/icon-32.png",
    "48": "media/icon-48.png",
    "128": "media/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "media/icon-16.png",
      "32": "media/icon-32.png",
      "48": "media/icon-48.png",
      "128": "media/icon-128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.ugent.be/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "unused/injected.js"
      ],
      "matches": [
        "https://*.ugent.be/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "UforaShortcutsExtension@arther-adriansens.github.io",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}